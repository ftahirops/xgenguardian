{
  "manifest_version": 3,
  "name": "XGenGuardian",
  "short_name": "XGG",
  "version": "0.3.4",
  "description": "Catches phishing your DNS missed. Per-URL evidence for every block.",
  "default_locale": "en",
  "icons": {
    "16":  "icons/icon-16.png",
    "32":  "icons/icon-32.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16":  "icons/icon-16.png",
      "32":  "icons/icon-32.png"
    }
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "tabs",
    "webNavigation",
    "webRequest",
    "declarativeNetRequest",
    "alarms",
    "scripting",
    "notifications"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/copy-guard.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "options_ui": {
    "page": "src/options.html",
    "open_in_tab": true
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "trackers",
        "enabled": true,
        "path": "src/rules/trackers.json"
      }
    ]
  },
  "web_accessible_resources": [
    {
      "resources": [
        "src/blocked.html",
        "src/blocked.js",
        "src/holding.html",
        "src/holding.js",
        "src/warn.html",
        "src/warn.js",
        "src/isolate.html",
        "src/isolate.js",
        "src/dnsfail.html",
        "src/dnsfail.js",
        "icons/*"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
